@page "/documentation"

<PageTitle>Documentation - XNet› Professional</PageTitle>

<main class="container-apple main-page">
    <!-- Doc Hero -->
    <div class="text-center mb-5 animate-fade">
        <h1 class="display-3 fw-bold text-white mb-3">Documentation</h1>
        <p class="hero-description mx-auto">Learn how to leverage the full power of XNet, from basic discovery to advanced terminal orchestration.</p>
    </div>

    <!-- Group: Core Infrastructure -->
    <div class="doc-category mb-5">
        <h2 class="h4 text-sf-secondary mb-4 border-bottom border-dark pb-2">Network Intelligence</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <a href="/documentation/ip-scanner" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-broadcast"></i></div>
                    <div class="doc-content">
                        <h3>IP Scanner</h3>
                        <p>Perform high-speed subnet discovery and vendor identification using ICMP and TCP probing.</p>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a href="/documentation/port-scanner" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-shield-lock"></i></div>
                    <div class="doc-content">
                        <h3>Port Scanner</h3>
                        <p>Identify active services and audit device security with rapid port sequencing.</p>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Group: Planning -->
    <div class="doc-category mb-5">
        <h2 class="h4 text-sf-secondary mb-4 border-bottom border-dark pb-2">Planning & Architecture</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <a href="/documentation/subnet-calculator" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-calculator"></i></div>
                    <div class="doc-content">
                        <h3>Subnet Calculator</h3>
                        <p>Visual networking math. Calculate ranges, masks, and partitioned subnets with 64-bit precision.</p>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a href="/documentation/vlsm" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-diagram-3"></i></div>
                    <div class="doc-content">
                        <h3>VLSM Breakdown</h3>
                        <p>Complex variable-length subnet masking made visual and interactive.</p>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Group: Operations -->
    <div class="doc-category mb-5">
        <h2 class="h4 text-sf-secondary mb-4 border-bottom border-dark pb-2">Operations & Terminal</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <a href="/documentation/terminal" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-terminal"></i></div>
                    <div class="doc-content">
                        <h3>Terminal Emulation</h3>
                        <p>Advanced SSH, Telnet, and Serial session management with protocol-aware negotiation.</p>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a href="/documentation/terminal" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                    <div class="doc-content">
                        <h3>Remote Transfer (FTP)</h3>
                        <p>Managing binary file transfers and synchronization using secure file protocols.</p>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Group: Diagnostics -->
    <div class="doc-category mb-5">
        <h2 class="h4 text-sf-secondary mb-4 border-bottom border-dark pb-2">Network Diagnostics</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <a href="/documentation/traceroute" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-geo-alt"></i></div>
                    <div class="doc-content">
                        <h3>Traceroute Analytics</h3>
                        <p>Analyze the path of data packets across network hops with real-time latency monitoring.</p>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a href="/documentation/ping" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-activity"></i></div>
                    <div class="doc-content">
                        <h3>Visual Ping</h3>
                        <p>Monitor host reachability with high-fidelity latency historical graphing.</p>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Group: Customization -->
    <div class="doc-category mb-5">
        <h2 class="h4 text-sf-secondary mb-4 border-bottom border-dark pb-2">Customization & App</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <a href="/documentation/themes" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-palette"></i></div>
                    <div class="doc-content">
                        <h3>Dynamic Themes</h3>
                        <p>Personlize your workspace with accent colors and native macOS dark mode orchestration.</p>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a href="/documentation/backup" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-archive"></i></div>
                    <div class="doc-content">
                        <h3>Backup & Recovery</h3>
                        <p>Safeguard your NetBox inventory and session history with robust export/import tools.</p>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Group: Community & Cloud -->
    <div class="doc-category mb-5">
        <h2 class="h4 text-sf-secondary mb-4 border-bottom border-dark pb-2">Ecosystem & Cloud</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <a href="/documentation/github" class="doc-card">
                    <div class="doc-icon"><i class="bi bi-github"></i></div>
                    <div class="doc-content">
                        <h3>Open Source & GitHub</h3>
                        <p>Learn how to contribute, report bugs, and explore the core engine source code on our repository.</p>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a href="/documentation/self-hosted" class="doc-card overflow-hidden">
                    <div class="doc-icon"><i class="bi bi-server"></i></div>
                    <div class="doc-content">
                        <h3>Self-Hosted Control</h3>
                        <p>Deploy your own XNet Instance for centralized documentation, node management, and encrypted log synchronization across your devices.</p>
                    </div>
                </a>
            </div>
        </div>
    </div>

</main>

<style>
    .doc-category h2 {
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 14px;
        font-weight: 600;
        color: var(--apple-text-secondary);
    }

    .doc-card {
        background: #1d1d1f;
        border-radius: 12px;
        padding: 24px;
        display: flex;
        gap: 20px;
        text-decoration: none;
        transition: transform 0.2s, background 0.2s;
        height: 100%;
        border: 1px solid transparent;
    }

    .doc-card:hover {
        background: #2d2d2f;
        transform: translateY(-2px);
        border-color: var(--apple-border);
    }

    .doc-icon {
        width: 44px;
        height: 44px;
        background: var(--apple-accent);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: white;
        flex-shrink: 0;
    }

    .doc-content h3 {
        font-size: 19px;
        font-weight: 600;
        color: var(--apple-text-white);
        margin-bottom: 4px;
    }

    .doc-content p {
        font-size: 15px;
        color: var(--apple-text-secondary);
        margin: 0;
        line-height: 1.4;
    }
</style>
