@page "/documentation/backup"

<PageTitle>Backup & Recovery - XNet› Docs</PageTitle>


<main class="container-apple main-page">
    <div class="doc-wrapper">
        <DocSidebar />
        <div class="doc-main-content animate-fade">
            <h1 class="display-4 fw-bold text-white mb-4">Backup & Recovery</h1>
            <p class="hero-description mb-5">Never lose your inventory. Securely export and import your XNet environment.</p>

            <div class="glass-card overflow-hidden mb-5">
                <img src="assets/screenshots/settings_backup.png" class="img-fluid" alt="Backup Settings" />
            </div>

            <div class="doc-section mb-5">
                <h2 class="h3 text-white mb-3">Data Portability</h2>
                <p class="text-sf-secondary">Export your entire device history, NetBox synchronized data, and saved credentials into a secure JSON-based archive. This allows for rapid migration between machines or disaster recovery.</p>
            </div>
        </div>
    </div>
</main>
