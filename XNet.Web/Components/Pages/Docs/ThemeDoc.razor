@page "/documentation/themes"

<PageTitle>Dynamic Themes - XNet› Docs</PageTitle>


<main class="container-apple main-page">
    <div class="doc-wrapper">
        <DocSidebar />
        <div class="doc-main-content animate-fade">
            <h1 class="display-4 fw-bold text-white mb-4">Personalization & Themes</h1>
            <p class="hero-description mb-5">Make your technical workspace truly yours with native SwiftUI customization.</p>

            <div class="glass-card overflow-hidden mb-5">
                <img src="assets/screenshots/settings_theme.png" class="img-fluid" alt="Theme Settings" />
            </div>

            <div class="doc-section mb-5">
                <h2 class="h3 text-white mb-3">Native macOS Material</h2>
                <p class="text-sf-secondary">XNet is built using Apple's material design. You can toggle between Light, Dark, or System matching modes, and choose from a curated palette of accent colors that flow through every UI component.</p>
            </div>
        </div>
    </div>
</main>
