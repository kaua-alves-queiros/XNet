@page "/documentation/subnet-calculator"

<PageTitle>IP Planner Docs - XNet›</PageTitle>


<main class="container-apple main-page">
    <div class="doc-wrapper">
        <DocSidebar />
        <div class="doc-main-content animate-fade">
            <h1 class="display-4 fw-bold text-white mb-4">IP Planner</h1>
            <p class="hero-description mb-5">Visual networking math. Calculate ranges, masks, and partitioned subnets.</p>

            <div class="glass-card overflow-hidden mb-5">
                <img src="assets/screenshots/subnet.png" class="img-fluid" alt="Subnet Calculator Interface" />
            </div>

            <div class="doc-section mb-5">
                <h2 class="h3 text-white mb-3">Precision Math</h2>
                <p class="text-sf-secondary">Built for exactness, the IP Planner provides a visual way to handle subnet masks, wildcards, and network boundaries. It handles 64-bit address calculations to ensure stability even with large IPv6-like address structures in future modules.</p>
            </div>
        </div>
    </div>
</main>
