@page "/documentation/terminal"

<PageTitle>Terminal Emulation Docs - XNet›</PageTitle>


<main class="container-apple main-page">
    <div class="doc-wrapper">
        <DocSidebar />
        <div class="doc-main-content animate-fade">
            <h1 class="display-4 fw-bold text-white mb-4">Terminal Emulation</h1>
            <p class="hero-description mb-5">Advanced SSH, Telnet, and Serial session management.</p>

            <!-- Visual Preview -->
            <div class="glass-card overflow-hidden mb-5">
                <img src="assets/screenshots/terminal.png" class="img-fluid" alt="Terminal Interface" />
            </div>

            <div class="doc-section mb-5">
                <h2 class="h3 text-white mb-3">Protocol Awareness</h2>
                <p class="text-sf-secondary">XNet Terminal is not just a pipe. It is protocol-aware, handling Telnet DONT/WONT negotiations and serial TermIOS settings with hardware-level precision. This prevents common issues like double echoes and character doubling found in generic emulators.</p>
            </div>
        </div>
    </div>
</main>
