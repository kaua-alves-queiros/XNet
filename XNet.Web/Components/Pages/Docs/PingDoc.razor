@page "/documentation/ping"

<PageTitle>Visual Ping - XNet› Docs</PageTitle>


<main class="container-apple main-page">
    <div class="doc-wrapper">
        <DocSidebar />
        <div class="doc-main-content animate-fade">
            <h1 class="display-4 fw-bold text-white mb-4">Visual Ping</h1>
            <p class="hero-description mb-5">High-fidelity latency monitoring with historical graphing and stability analysis.</p>

            <div class="glass-card overflow-hidden mb-5">
                <img src="assets/screenshots/ping.png" class="img-fluid" alt="Visual Ping Interface" />
            </div>

            <div class="doc-section mb-5">
                <h2 class="h3 text-white mb-3">Reachability Analysis</h2>
                <p class="text-sf-secondary">XNet Ping provides more than just a reply time. It tracks jitter, packet loss, and latency trends over time, visualising them in a native macOS chart for instant health assessment of any host.</p>
            </div>
        </div>
    </div>
</main>
