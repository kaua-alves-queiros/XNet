@page "/documentation/traceroute"

<PageTitle>Traceroute Analytics - XNet› Docs</PageTitle>


<main class="container-apple main-page">
    <div class="doc-wrapper">
        <DocSidebar />
        <div class="doc-main-content animate-fade">
            <h1 class="display-4 fw-bold text-white mb-4">Traceroute Analytics</h1>
            <p class="hero-description mb-5">Identify the path of packets and isolate bottlenecks in your network routing.</p>

            <div class="glass-card overflow-hidden mb-5">
                <img src="assets/screenshots/traceroute.png" class="img-fluid" alt="Traceroute Interface" />
            </div>

            <div class="doc-section mb-5">
                <h2 class="h3 text-white mb-3">Path Discovery</h2>
                <p class="text-sf-secondary">XNet uses incremental TTL probing to discover exactly which routers (hops) your data passes through. This is essential for debugging ISP routing issues or complex MPLS/VPN environments.</p>
            </div>
        </div>
    </div>
</main>
