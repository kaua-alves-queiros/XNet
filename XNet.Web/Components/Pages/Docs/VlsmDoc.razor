@page "/documentation/vlsm"

<PageTitle>VLSM Breakdown Docs - XNet›</PageTitle>


<main class="container-apple main-page">
    <div class="doc-wrapper">
        <DocSidebar />
        <div class="doc-main-content animate-fade">
            <h1 class="display-4 fw-bold text-white mb-4">VLSM Breakdown</h1>
            <p class="hero-description mb-5">Complex variable-length subnet masking made visual and interactive.</p>

            <div class="glass-card overflow-hidden mb-5">
                <img src="assets/screenshots/subnet_breakdown.png" class="img-fluid" alt="VLSM Interface" />
            </div>

            <div class="doc-section mb-5">
                <h2 class="h3 text-white mb-3">Host-Based Partitioning</h2>
                <p class="text-sf-secondary">The VLSM tool allows you to input the number of required hosts for multiple subnets and automatically calculates the most efficient address allocation, minimizing wasted IP space across your local networks.</p>
            </div>
        </div>
    </div>
</main>
