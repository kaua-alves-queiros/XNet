@page "/setup"
@using Microsoft.AspNetCore.Authorization
@using XNet.SelfHosted.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager Nav
@inject SignInManager<ApplicationUser> SignInManager

<PageTitle>Setup - XNet SelfHosted</PageTitle>

@using XNet.Shared.Components.CocoUi

<PageTitle>Setup Engine — XNet Self-Hosted</PageTitle>

<div class="setup-canvas">
    <div class="glow-sphere sphere-1"></div>
    <div class="glow-sphere sphere-2"></div>
    
    <CocoCard Class="setup-container animate-fade-in" Style="max-width: 500px; padding: 48px;">
        <div class="text-center mb-5">
            <div class="setup-icon-box mb-4">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <CocoHeading Level="1" Class="text-white mb-2">Initialize XNet</CocoHeading>
            <p class="text-tertiary">Configure your private self-hosted instance and master administrator.</p>
        </div>

        @if (step == 1)
        {
            <div class="animate-slide-up">
                <div class="step-label">PHASE 01 — INFRASTRUCTURE</div>
                <h3 class="text-white h5 mb-4">Organization Identity</h3>
                
                <div class="mb-5">
                    <CocoInput Label="ORGANIZATION NAME" 
                               Placeholder="e.g. Acme Network Instance" 
                               @bind-Value="orgName" />
                    <p class="small text-tertiary mt-2">This will be shown in all headers and reports.</p>
                </div>
                
                <CocoButton Variant="primary" Class="w-100 py-3" OnClick="() => step = 2">
                    Proceed to Admin <i class="bi bi-arrow-right ms-2"></i>
                </CocoButton>
            </div>
        }
        else if (step == 2)
        {
            <div class="animate-slide-up">
                <div class="step-label">PHASE 02 — SECURITY</div>
                <h3 class="text-white h5 mb-4">Master Administrator</h3>
                
                <div class="mb-4">
                    <CocoInput Label="ADMIN EMAIL" 
                               Type="email"
                               Placeholder="admin@xnet.internal" 
                               @bind-Value="adminEmail" />
                </div>
                
                <div class="mb-5">
                    <CocoInput Label="SECURE PASSWORD" 
                               Type="password"
                               Placeholder="••••••••" 
                               @bind-Value="adminPassword" />
                    <p class="small text-tertiary mt-2">Minimum 6 characters required for encryption.</p>
                </div>
                
                <div class="d-flex gap-3">
                    <CocoButton Variant="secondary" Class="w-50" OnClick="() => step = 1">
                        Back
                    </CocoButton>
                    <CocoButton Variant="primary" Class="w-50" OnClick="FinishSetup" Loading="@isProcessing">
                        Finalize Setup <i class="bi bi-rocket-takeoff ms-2"></i>
                    </CocoButton>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="error-alert mt-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @error
            </div>
        }
        
        <div class="setup-footer mt-5 text-center">
            <span class="text-tertiary small">XNet Self-Hosted v2.5.0</span>
        </div>
    </CocoCard>
</div>

<style>
    .setup-canvas {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #09090b;
        position: relative;
        overflow: hidden;
        padding: 40px 20px;
    }

    .glow-sphere {
        position: absolute;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.15;
        z-index: 0;
    }
    .sphere-1 { top: -100px; right: -100px; background: var(--xnet-accent); }
    .sphere-2 { bottom: -100px; left: -100px; background: #6366f1; }

    .setup-container {
        position: relative;
        z-index: 2;
    }

    .setup-icon-box {
        width: 64px;
        height: 64px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        font-size: 28px;
        color: var(--xnet-accent);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .step-label {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.15em;
        color: var(--xnet-accent);
        margin-bottom: 12px;
        opacity: 0.8;
    }

    .error-alert {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #ef4444;
        padding: 14px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 500;
        text-align: center;
    }

    .animate-slide-up {
        animation: slideUp 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private int step = 1;
    private string orgName = "";
    private string adminEmail = "";
    private string adminPassword = "";
    private string? error;
    private bool isProcessing;

    protected override async Task OnInitializedAsync()
    {
        var orgExists = await Db.Organizations.AnyAsync(o => o.IsConfigured);
        if (orgExists) Nav.NavigateTo("/", true);
    }

    private async Task FinishSetup()
    {
        if (string.IsNullOrWhiteSpace(adminEmail) || string.IsNullOrWhiteSpace(adminPassword) || string.IsNullOrWhiteSpace(orgName))
        {
            error = "All fields are required.";
            return;
        }

        isProcessing = true;
        error = null;

        try
        {
            var org = new Organization 
            { 
                Name = orgName, 
                IsConfigured = true 
            };
            Db.Organizations.Add(org);
            await Db.SaveChangesAsync();

            if (!await RoleManager.RoleExistsAsync("Admin")) await RoleManager.CreateAsync(new IdentityRole("Admin"));
            if (!await RoleManager.RoleExistsAsync("User")) await RoleManager.CreateAsync(new IdentityRole("User"));

            var user = new ApplicationUser { UserName = adminEmail, Email = adminEmail, IsActive = true };
            var result = await UserManager.CreateAsync(user, adminPassword);

            if (result.Succeeded)
            {
                await UserManager.AddToRoleAsync(user, "Admin");
                // Redireciona para o login para evitar erro de Headers Read-only
                Nav.NavigateTo("Account/Login", true);
            }
            else
            {
                error = result.Errors.FirstOrDefault()?.Description ?? "Master account creation failed.";
            }
        }
        catch (Exception ex)
        {
            error = "Critical error: " + ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }
}
