@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@attribute [Authorize]
@layout DashboardLayout
@inject XNet.SelfHosted.Data.ApplicationDbContext Db
@inject NavigationManager Nav
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Dashboard - XNet Console</PageTitle>

<div class="animate-fade">
    <div style="margin-bottom: 40px; border: none !important; outline: none !important;">
        <h1 style="color: #fff; font-size: 32px; font-weight: 700; margin-bottom: 8px; border: none !important; outline: none !important; box-shadow: none !important;">Synchronization Hub</h1>
        <p style="color: #6e6e73; font-size: 15px; margin: 0;">Central repository for cross-platform network documentation.</p>
    </div>

    <!-- Stats Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <CocoCard Class="p-4 card-glow-hover">
                <div class="d-flex justify-content-between mb-3">
                    <div class="stat-icon bg-blue-soft"><i class="bi bi-hdd-network-fill text-blue"></i></div>
                    <CocoBadge Status="CocoBadge.CocoStatus.Info">Devices</CocoBadge>
                </div>
                <div class="text-tertiary small uppercase fw-bold mb-1">TOTAL NODES</div>
                <div class="h3 fw-bold m-0">@deviceCount</div>
            </CocoCard>
        </div>
        <div class="col-md-3">
            <CocoCard Class="p-4 card-glow-hover">
                <div class="d-flex justify-content-between mb-3">
                    <div class="stat-icon bg-purple-soft"><i class="bi bi-terminal-fill text-purple"></i></div>
                    <CocoBadge Status="CocoBadge.CocoStatus.Success">Sessions</CocoBadge>
                </div>
                <div class="text-tertiary small uppercase fw-bold mb-1">TOTAL LOGS</div>
                <div class="h3 fw-bold m-0">@logCount</div>
            </CocoCard>
        </div>
        <div class="col-md-3">
            <CocoCard Class="p-4 card-glow-hover">
                <div class="d-flex justify-content-between mb-3">
                    <div class="stat-icon bg-green-soft"><i class="bi bi-box-seam-fill text-green"></i></div>
                    <CocoBadge Status="CocoBadge.CocoStatus.Info">NetBox</CocoBadge>
                </div>
                <div class="text-tertiary small uppercase fw-bold mb-1">SYNC OBJECTS</div>
                <div class="h3 fw-bold m-0">@netBoxCount</div>
            </CocoCard>
        </div>
        <div class="col-md-3">
            <CocoCard Class="p-4 card-glow-hover">
                <div class="d-flex justify-content-between mb-3">
                    <div class="stat-icon bg-orange-soft"><i class="bi bi-people-fill text-orange"></i></div>
                    <CocoBadge Status="CocoBadge.CocoStatus.Success">Users</CocoBadge>
                </div>
                <div class="text-tertiary small uppercase fw-bold mb-1">ACTIVE ACCOUNTS</div>
                <div class="h3 fw-bold m-0">@userCount</div>
            </CocoCard>
        </div>
    </div>

    <!-- Charts -->
    <div class="row g-4 mb-5">
        <div class="col-lg-12">
            <CocoCard Class="p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h3 class="h6 fw-bold m-0 uppercase letter-spacing-1">Synchronization Activity</h3>
                        <p class="small text-tertiary mt-1">Live data consistency stream (Last 7 Days)</p>
                    </div>
                    <div class="d-flex gap-4">
                        <div class="chart-legend">
                            <span class="dot bg-blue"></span>
                            <span class="small text-tertiary">Operations / Day</span>
                        </div>
                    </div>
                </div>
                <div class="chart-container">
                    <svg viewBox="0 0 1200 220" class="w-100" preserveAspectRatio="none">
                        <defs>
                            <linearGradient id="chartGradient" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="#00b4ff" stop-opacity="0.3" />
                                <stop offset="100%" stop-color="#00b4ff" stop-opacity="0" />
                            </linearGradient>
                        </defs>
                        
                        <!-- Grid Lines -->
                        <line x1="0" y1="50" x2="1200" y2="50" stroke="rgba(255,255,255,0.03)" />
                        <line x1="0" y1="100" x2="1200" y2="100" stroke="rgba(255,255,255,0.03)" />
                        <line x1="0" y1="150" x2="1200" y2="150" stroke="rgba(255,255,255,0.03)" />

                        <path d="@GenerateChartPath()" fill="url(#chartGradient)" />
                        <path d="@GenerateChartLine()" stroke="#00b4ff" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                        
                        <g>
                        @for (int i = 0; i < 7; i++)
                        {
                            var x = i * (1200 / 6);
                            var val = dailyActivity[i];
                            var y = 180 - Math.Min(val * 15, 170);
                            <circle cx="@x" cy="@y" r="5" fill="#00b4ff" stroke="#000" stroke-width="2" />
                            <svg:text x="@x" y="210" text-anchor="middle" fill="#6e6e73" font-size="11" font-weight="600">@days[i]</svg:text>
                            @if (val > 0) {
                                <svg:text x="@x" y="@(y - 12)" text-anchor="middle" fill="#fff" font-size="10" font-weight="700">@val</svg:text>
                            }
                        }
                        </g>
                    </svg>
                </div>
            </CocoCard>
        </div>
    </div>

    <!-- Recent Terminal Sessions -->
    <div>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="h6 fw-bold m-0 uppercase letter-spacing-1">Recent Terminal Sessions</h3>
            <a href="terminal-logs" class="small text-blue text-decoration-none">View All History <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
        <CocoCard Class="p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="coco-home-table">
                    <thead>
                        <tr>
                            <th>TITLE</th>
                            <th>HOST</th>
                            <th>PROTOCOL</th>
                            <th>TIMESTAMP</th>
                            <th class="text-end">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!recentLogs.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-tertiary italic">
                                    <i class="bi bi-clock-history d-block mb-3 h2 opacity-10"></i>
                                    No remote activity recorded yet.
                                </td>
                            </tr>
                        }
                        @foreach (var log in recentLogs)
                        {
                            <tr>
                                <td class="fw-bold text-white">@log.Title</td>
                                <td class="text-tertiary">@log.Host</td>
                                <td><CocoBadge Status="CocoBadge.CocoStatus.Info">@log.ConnectionType</CocoBadge></td>
                                <td>@log.StartedAt.ToString("g")</td>
                                <td class="text-end">
                                    <button class="btn-ghost" @onclick='() => Nav.NavigateTo("/terminal-logs")'><i class="bi bi-box-arrow-up-right"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </CocoCard>
    </div>
</div>

<style>
    .stat-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
    .bg-blue-soft { background: rgba(0, 180, 255, 0.1); border: 1px solid rgba(0, 180, 255, 0.1); }
    .bg-purple-soft { background: rgba(191, 90, 242, 0.1); border: 1px solid rgba(191, 90, 242, 0.1); }
    .bg-green-soft { background: rgba(52, 199, 89, 0.1); border: 1px solid rgba(52, 199, 89, 0.1); }
    .bg-orange-soft { background: rgba(255, 159, 10, 0.1); border: 1px solid rgba(255, 159, 10, 0.1); }
    
    .text-blue { color: #00b4ff; }
    .text-purple { color: #bf5af2; }
    .text-green { color: #34c759; }
    .text-orange { color: #ff9f0a; }

    .coco-home-table { width: 100%; font-size: 13px; border-collapse: collapse; }
    .coco-home-table th { padding: 18px 24px; color: #6e6e73; font-size: 10px; font-weight: 800; text-transform: uppercase; border-bottom: 1px solid rgba(255,255,255,0.05); text-align: left; }
    .coco-home-table td { padding: 18px 24px; border-bottom: 1px solid rgba(255,255,255,0.02); vertical-align: middle; }

    .card-glow-hover { transition: all 0.4s cubic-bezier(0.2, 1, 0.2, 1); border: 1px solid rgba(255,255,255,0.05) !important; }
    .card-glow-hover:hover { border-color: rgba(255,255,255,0.2) !important; transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.5); }

    .btn-ghost { background: none; border: none; color: #6e6e73; padding: 6px; border-radius: 8px; transition: 0.2s; }
    .btn-ghost:hover { color: #00b4ff; background: rgba(0, 180, 255, 0.1); }

    .chart-legend { display: flex; align-items: center; gap: 8px; }
    .dot { width: 8px; height: 8px; border-radius: 50%; }
    .bg-blue { background: #00b4ff; }
    
    .chart-container { height: 240px; }
</style>

@code {
    private List<TerminalLog> recentLogs = new();
    private int deviceCount;
    private int logCount;
    private int netBoxCount;
    private int userCount;
    private int[] dailyActivity = new int[7];
    private string[] days = new string[7];

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            var orgExists = await Db.Organizations.AnyAsync(o => o.IsConfigured);
            if (!orgExists) Nav.NavigateTo("/setup", true);

            recentLogs = await Db.TerminalLogs
                .OrderByDescending(l => l.StartedAt)
                .Take(5)
                .ToListAsync();

            deviceCount = await Db.Devices.CountAsync();
            logCount = await Db.TerminalLogs.CountAsync();
            userCount = await UserManager.Users.CountAsync();

            netBoxCount = await Db.NetBoxSites.CountAsync() + 
                          await Db.NetBoxPrefixes.CountAsync() + 
                          await Db.NetBoxVLANs.CountAsync() + 
                          await Db.NetBoxDevices.CountAsync() + 
                          await Db.NetBoxIPs.CountAsync();

            // Fetch real daily activity
            for (int i = 0; i < 7; i++)
            {
                var date = DateTime.Today.AddDays(-(6 - i));
                var nextDate = date.AddDays(1);
                
                var count = await Db.Logs.CountAsync(l => l.Timestamp >= date && l.Timestamp < nextDate) +
                            await Db.TerminalLogs.CountAsync(l => l.StartedAt >= date && l.StartedAt < nextDate);
                
                dailyActivity[i] = count;
                days[i] = date.ToString("ddd").ToUpper();
            }
        }
        catch (Exception) { }
    }

    private string GenerateChartLine()
    {
        var points = new List<string>();
        for (int i = 0; i < 7; i++)
        {
            var x = i * (1200 / 6);
            var y = 180 - Math.Min(dailyActivity[i] * 15, 170);
            points.Add(i == 0 ? $"M{x},{y}" : $"L{x},{y}");
        }
        return string.Join(" ", points);
    }

    private string GenerateChartPath()
    {
        var line = GenerateChartLine();
        if (string.IsNullOrEmpty(line)) return "";
        return $"{line} L1200,220 L0,220 Z";
    }
}
