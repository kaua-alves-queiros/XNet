@page "/devices"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using XNet.Shared.Models
@attribute [Authorize]
@layout DashboardLayout
@inject XNet.SelfHosted.Data.ApplicationDbContext Db
@inject NavigationManager Nav

<PageTitle>Devices - XNet Console</PageTitle>

<div class="animate-fade">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="text-white mb-2">Network Devices</h1>
            <p class="text-description">Manage and monitor your endpoints connected to this Self-Hosted instance.</p>
        </div>
    </div>

    <!-- Devices Grid/Table -->
    <CocoCard Class="p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark-custom m-0">
                <thead>
                    <tr>
                        <th class="ps-4">DEVICE NAME</th>
                        <th>HOST / ADDRESS</th>
                        <th>TYPE</th>
                        <th>LAST SEEN</th>
                        <th class="pe-4 text-end">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!devices.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="bi bi-hdd-network display-4 d-block mb-3 text-tertiary"></i>
                                    <p class="text-tertiary">No devices registered in this Self-Hosted instance yet.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var device in devices)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="device-icon"><i
                                                class="bi @(device.ConnectionType == "SSH" ? "bi-terminal-fill" : "bi-hdd-stack-fill")"></i>
                                        </div>
                                        <div class="fw-bold text-white">@device.Name</div>
                                    </div>
                                </td>
                                <td class="text-secondary font-monospace">@device.Host:@device.Port</td>
                                <td>
                                    <CocoBadge Status="CocoBadge.CocoStatus.Info">@device.ConnectionType</CocoBadge>
                                </td>
                                <td class="text-tertiary small">
                                    @DateTime.UtcNow.AddMinutes(-5).ToString("HH:mm") <span
                                        class="opacity-50">(Real-time)</span>
                                </td>
                                <td class="pe-4 text-end">
                                    <button class="btn-action"><i class="bi bi-gear"></i></button>
                                    <button class="btn-action ms-2"><i class="bi bi-activity"></i></button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </CocoCard>
</div>

<style>
    .table-dark-custom {
        --bs-table-bg: transparent;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-dark-custom thead th {
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        color: #6e6e73;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        padding: 16px 12px;
    }

    .table-dark-custom tbody td {
        padding: 20px 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        vertical-align: middle;
        color: #acacb3;
        font-size: 14px;
    }

    .device-icon {
        width: 32px;
        height: 32px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--xnet-accent);
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .pulse-green {
        background: #34c759;
        box-shadow: 0 0 0 0 rgba(52, 199, 89, 0.4);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(52, 199, 89, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(52, 199, 89, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(52, 199, 89, 0);
        }
    }

    .btn-action {
        background: rgba(255, 255, 255, 0.05);
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .btn-action:hover {
        background: var(--xnet-accent);
        transform: translateY(-2px);
    }

    .empty-state {
        opacity: 0.5;
    }
</style>

@code {
    private List<Device> devices = new();

    protected override async Task OnInitializedAsync()
    {
        devices = await Db.Devices.OrderByDescending(d => d.CreatedAt).ToListAsync();
    }
}
