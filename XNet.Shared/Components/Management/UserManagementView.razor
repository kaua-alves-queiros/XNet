@namespace XNet.Shared.Components.Management
@using Microsoft.AspNetCore.Identity
@using XNet.Shared.Models
@using XNet.Shared.Components.CocoUi
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager

<div class="animate-fade">
    @if (showAdd)
    {
        <div class="coco-form-card animate-fade">
            <div class="form-header">
                <span class="form-badge">NEW USER</span>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <CocoInput Label="EMAIL" @bind-Value="newEmail" Placeholder="user@domain.com" />
                </div>
                <div class="form-group">
                    <CocoInput Label="PASSWORD" Type="password" @bind-Value="newPassword" Placeholder="••••••••" />
                </div>
                <div class="form-group">
                    <label class="coco-label-standalone">PERMISSIONS</label>
                    <div class="coco-select-container">
                        <select @bind="newRole" class="coco-select">
                            <option value="Admin">Administrator</option>
                            <option value="User">Standard User</option>
                        </select>
                        <i class="bi bi-chevron-down select-chevron"></i>
                    </div>
                </div>
                <div class="form-actions">
                    <CocoButton Class="w-100" OnClick="CreateUser" Loading="@isProcessing">Save User</CocoButton>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(error)) { <div class="text-danger mt-3 small px-2">@error</div> }
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="text-white mb-2" style="border: none !important; outline: none !important;">User Management</h1>
            <p class="text-description">Manage roles and security for your organization.</p>
        </div>
        <CocoButton Type="CocoButton.CocoType.Primary" Icon="bi-person-plus" OnClick="() => showAdd = !showAdd">
            Add Account
        </CocoButton>
    </div>

    <CocoCard Class="p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table user-table-custom m-0">
                <thead>
                    <tr>
                        <th class="ps-4">USER</th>
                        <th>ROLE</th>
                        <th>STATUS</th>
                        <th class="pe-4 text-end">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in userList)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="user-avatar-small">@(user.Email?[0].ToString().ToUpper())</div>
                                    <div>
                                        <div class="fw-bold text-white">@user.Email</div>
                                        <div class="text-tertiary" style="font-size: 11px;">Joined @user.CreatedAt.ToString("MM/dd/yyyy")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <CocoBadge Status="@(IsAdmin(user) ? CocoBadge.CocoStatus.Info : CocoBadge.CocoStatus.Info)">
                                    @userRoles.GetValueOrDefault(user.Id, "User")
                                </CocoBadge>
                            </td>
                            <td>
                                <CocoBadge Status="@(user.IsActive ? CocoBadge.CocoStatus.Success : CocoBadge.CocoStatus.Danger)">
                                    @(user.IsActive ? "ACTIVE" : "SUSPENDED")
                                </CocoBadge>
                            </td>
                            <td class="pe-4 text-end">
                                <button class="btn-action" @onclick="() => ToggleStatus(user)">
                                    <i class="bi @(user.IsActive ? "bi-person-x" : "bi-person-check")"></i>
                                </button>
                                @if (user.Email != "admin@example.com")
                                {
                                    <button class="btn-action ms-2" @onclick="() => DeleteUser(user)"><i class="bi bi-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </CocoCard>
</div>

<style>
    .management-subtitle { color: var(--coco-text-secondary); font-size: 15px; margin: 0; }

    .coco-form-card { 
        background: rgba(40, 40, 42, 0.3); border: 1px solid var(--coco-card-border); 
        border-radius: 20px; padding: 24px; margin-bottom: 40px;
    }
    .form-header { margin-bottom: 20px; }
    .form-badge { font-size: 10px; font-weight: 800; color: var(--coco-blue); letter-spacing: 0.12em; opacity: 0.8; }
    
    .form-row { display: grid; grid-template-columns: 1fr 1fr 1fr 160px; gap: 20px; align-items: flex-end; }
    .coco-label-standalone { display: block; font-size: 11px; font-weight: 700; color: var(--coco-text-secondary); letter-spacing: 0.08em; margin-bottom: 10px; margin-left: 4px; }
    
    .coco-select-container { position: relative; }
    .select-chevron { position: absolute; right: 14px; top: 14px; color: var(--coco-text-tertiary); pointer-events: none; font-size: 12px; }

    .user-table-custom { --bs-table-bg: transparent; border-collapse: separate; border-spacing: 0; }
    .user-table-custom thead th { 
        background: rgba(255,255,255,0.02); 
        border-bottom: 1px solid rgba(255,255,255,0.05);
        color: #6e6e73; font-size: 11px; font-weight: 700; letter-spacing: 1px;
        padding: 16px 12px;
    }
    .user-table-custom tbody td { 
        padding: 20px 12px; 
        border-bottom: 1px solid rgba(255,255,255,0.05); vertical-align: middle;
        color: #acacb3; font-size: 14px;
    }

    .user-avatar-small { 
        width: 32px; height: 32px; background: rgba(255,255,255,0.05); 
        border-radius: 8px; display: flex; align-items: center; justify-content: center;
        color: #fff; font-weight: 700; font-size: 12px;
    }

    .btn-action { 
        background: rgba(255,255,255,0.05); border: none; width: 32px; height: 32px; 
        border-radius: 8px; color: #fff; display: inline-flex; align-items: center; justify-content: center;
        transition: all 0.2s;
    }
    .btn-action:hover { background: rgba(255,255,255,0.1); transform: translateY(-2px); }
    .btn-action i { font-size: 14px; }
</style>

@code {
    private List<ApplicationUser> userList = new();
    private Dictionary<string, string> userRoles = new();
    private bool showAdd;
    private string newEmail = "";
    private string newPassword = "";
    private string newRole = "User";
    private string? error;
    private bool isProcessing;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        userList = UserManager.Users.ToList();
        userRoles.Clear();
        foreach (var u in userList)
        {
            var roles = await UserManager.GetRolesAsync(u);
            userRoles[u.Id] = roles.FirstOrDefault() ?? "User";
        }
    }

    private bool IsAdmin(ApplicationUser u) => userRoles.GetValueOrDefault(u.Id) == "Admin";

    private async Task ToggleStatus(ApplicationUser u)
    {
        u.IsActive = !u.IsActive;
        await UserManager.UpdateAsync(u);
        await LoadUsers();
    }

    private async Task DeleteUser(ApplicationUser u)
    {
        await UserManager.DeleteAsync(u);
        await LoadUsers();
    }

    private async Task CreateUser()
    {
        if (string.IsNullOrWhiteSpace(newEmail) || string.IsNullOrWhiteSpace(newPassword)) return;
        isProcessing = true;
        
        var user = new ApplicationUser { UserName = newEmail, Email = newEmail, IsActive = true };
        var result = await UserManager.CreateAsync(user, newPassword);
        
        if (result.Succeeded)
        {
            await UserManager.AddToRoleAsync(user, newRole);
            newEmail = ""; newPassword = ""; showAdd = false;
            await LoadUsers();
        }
        else
        {
            error = result.Errors.FirstOrDefault()?.Description;
        }
        isProcessing = false;
    }
}
