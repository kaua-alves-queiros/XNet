@namespace XNet.Shared.Components.Management
@using Microsoft.AspNetCore.Identity
@using XNet.Shared.Models
@using XNet.Shared.Components.CocoUi
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager

<div class="animate-fade">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="text-white m-0">User Management</h1>
            <p class="text-description mb-0">Manage roles and security for your organization.</p>
        </div>
        <CocoButton OnClick="() => showAdd = !showAdd">
            <i class="bi bi-person-plus-fill me-2"></i> Add Account
        </CocoButton>
    </div>

    @if (showAdd)
    {
        <CocoCard Class="p-4 mb-5 animate-fade border-primary-soft">
            <h3 class="h6 fw-bold text-white mb-4 uppercase letter-spacing-1">New User</h3>
            <div class="row g-3">
                <div class="col-md-3">
                    <CocoInput Label="EMAIL" @bind-Value="newEmail" Placeholder="user@domain.com" />
                </div>
                <div class="col-md-3">
                    <CocoInput Label="PASSWORD" Type="password" @bind-Value="newPassword" Placeholder="••••••••" />
                </div>
                <div class="col-md-3">
                    <label class="form-label-apple">PERMISSIONS</label>
                    <select @bind="newRole" class="apple-input w-100" style="appearance: auto;">
                        <option value="Admin">Administrator</option>
                        <option value="User">Standard User</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <CocoButton Class="w-100 py-3" OnClick="CreateUser" Loading="@isProcessing">Save User</CocoButton>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(error)) { <div class="text-danger mt-3 small">@error</div> }
        </CocoCard>
    }

    <CocoCard Class="p-0 overflow-hidden">
        <table class="table table-dark table-hover m-0 apple-table">
            <thead>
                <tr>
                    <th class="ps-4">USER</th>
                    <th>ROLE</th>
                    <th>STATUS</th>
                    <th class="text-end pe-4">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in userList)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3 py-2">
                                <div class="user-avatar-sm">@user.Email?[0].ToString().ToUpper()</div>
                                <div>
                                    <div class="fw-bold">@user.Email</div>
                                    <div class="text-tertiary smaller">Joined @user.CreatedAt.ToShortDateString()</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <CocoBadge Text="@userRoles.GetValueOrDefault(user.Id, "User")" 
                                       Status="@(IsAdmin(user) ? CocoBadge.CocoStatus.Info : CocoBadge.CocoStatus.Info)" />
                        </td>
                        <td>
                            <CocoBadge Text="@(user.IsActive ? "ACTIVE" : "SUSPENDED")" 
                                       Status="@(user.IsActive ? CocoBadge.CocoStatus.Success : CocoBadge.CocoStatus.Danger)" />
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-link text-white-50 text-decoration-none" @onclick="() => ToggleStatus(user)">
                                @(user.IsActive ? "Deactivate" : "Activate")
                            </button>
                            @if (user.Email != "admin@admin.com")
                            {
                                <button class="btn btn-sm btn-link text-danger text-decoration-none ms-2" @onclick="() => DeleteUser(user)">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </CocoCard>
</div>

<style>
    .apple-table th { background: rgba(255,255,255,0.02); color: #8e8e93; font-size: 11px; font-weight: 700; padding: 16px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .apple-table td { padding: 16px; border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle; }
    .user-avatar-sm { width: 32px; height: 32px; background: rgba(255,255,255,0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; }
</style>

@code {
    private List<ApplicationUser> userList = new();
    private Dictionary<string, string> userRoles = new();
    private bool showAdd;
    private string newEmail = "";
    private string newPassword = "";
    private string newRole = "User";
    private string? error;
    private bool isProcessing;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        userList = UserManager.Users.ToList();
        userRoles.Clear();
        foreach (var u in userList)
        {
            var roles = await UserManager.GetRolesAsync(u);
            userRoles[u.Id] = roles.FirstOrDefault() ?? "User";
        }
    }

    private bool IsAdmin(ApplicationUser u) => userRoles.GetValueOrDefault(u.Id) == "Admin";

    private async Task ToggleStatus(ApplicationUser u)
    {
        u.IsActive = !u.IsActive;
        await UserManager.UpdateAsync(u);
        await LoadUsers();
    }

    private async Task DeleteUser(ApplicationUser u)
    {
        await UserManager.DeleteAsync(u);
        await LoadUsers();
    }

    private async Task CreateUser()
    {
        if (string.IsNullOrWhiteSpace(newEmail) || string.IsNullOrWhiteSpace(newPassword)) return;
        isProcessing = true;
        
        var user = new ApplicationUser { UserName = newEmail, Email = newEmail, IsActive = true };
        var result = await UserManager.CreateAsync(user, newPassword);
        
        if (result.Succeeded)
        {
            await UserManager.AddToRoleAsync(user, newRole);
            newEmail = ""; newPassword = ""; showAdd = false;
            await LoadUsers();
        }
        else
        {
            error = result.Errors.FirstOrDefault()?.Description;
        }
        isProcessing = false;
    }
}
