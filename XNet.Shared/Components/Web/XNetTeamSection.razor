@namespace XNet.Shared.Components.Web
@using XNet.Shared.Models

<section class="team-section py-5 text-center" id="team">
    <div class="container-apple">
        <h2 class="display-5 fw-bold text-white mb-2">Development Team</h2>
        <p class="text-secondary mb-5">The innovation behind XNet is driven by a passionate community of engineers.</p>
        
        <div class="row g-4 justify-content-center">
            @foreach (var dev in Contributors)
            {
                <div class="col-md-6 col-lg-4">
                    <a href="@dev.HtmlUrl" target="_blank" class="text-decoration-none h-100 d-block">
                        <div class="xnet-card h-100 text-start p-4 d-flex flex-column align-items-center text-center">
                            <img src="@dev.AvatarUrl" class="rounded-circle mb-4 border border-2 border-dark" style="width: 100px; height: 100px; object-fit: cover;" />
                            <h3 class="h4 fw-bold mb-2 text-white">@dev.Name</h3>
                            <p class="small text-secondary mb-3" style="font-size: 13px; line-height: 1.4;">@(dev.Bio ?? "Core Contributor")</p>
                            @if (!string.IsNullOrEmpty(dev.Company))
                            {
                                <p class="fw-bold mb-3" style="color: #4cd964; font-size: 14px;">@dev.Company</p>
                            }
                            <div class="mt-auto pt-3 w-100 border-top border-white-05">
                                <span class="text-secondary small">@dev.Contributions commits</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

@code {
    [Parameter] public List<GitHubContributor> Contributors { get; set; } = new();
}
