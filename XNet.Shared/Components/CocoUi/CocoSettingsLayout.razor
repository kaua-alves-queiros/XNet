@namespace XNet.Shared.Components.CocoUi

<div class="xnet-settings-wrapper animate-fade">
    <div class="xnet-settings-container">
        <aside class="xnet-settings-sidebar">
            <div class="sidebar-header pb-3 mb-3 border-bottom border-white border-opacity-10">
                <span class="text-secondary fw-bold text-uppercase small" style="letter-spacing: 0.1em;">Settings</span>
            </div>
            <nav class="xnet-settings-nav">
                @foreach (var tab in Tabs)
                {
                    <div class="xnet-settings-nav-item @(ActiveTab == tab.Id ? "active" : "")" @onclick="() => OnTabChanged.InvokeAsync(tab.Id)">
                        <div class="nav-icon">
                            <i class="bi @tab.Icon"></i>
                        </div>
                        <span class="nav-label">@tab.Label</span>
                        @if (ActiveTab == tab.Id)
                        {
                            <div class="active-indicator"></div>
                        }
                    </div>
                }
            </nav>
        </aside>

        <main class="xnet-settings-content">
            <div class="content-glass-bg"></div>
            <div class="content-inner">
                @ChildContent
            </div>
        </main>
    </div>
</div>

<style>
    .xnet-settings-wrapper {
        padding: 40px;
        min-height: 80vh;
        display: flex;
        justify-content: center;
    }

    .xnet-settings-container {
        display: flex !important;
        width: 100% !important;
        max-width: 1100px !important;
        background: rgba(30, 30, 32, 0.4) !important;
        backdrop-filter: blur(40px) !important;
        -webkit-backdrop-filter: blur(40px) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 24px !important;
        overflow: hidden !important;
        box-shadow: 0 40px 100px rgba(0,0,0,0.5) !important;
    }

    .xnet-settings-sidebar {
        width: 260px !important;
        background: rgba(255, 255, 255, 0.02) !important;
        border-right: 1px solid rgba(255, 255, 255, 0.05) !important;
        padding: 32px 16px !important;
    }

    .xnet-settings-nav-item {
        display: flex;
        align-items: center;
        padding: 10px 14px;
        border-radius: 10px;
        margin-bottom: 4px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.2, 1, 0.2, 1);
        position: relative;
        color: #a1a1a6;
    }

    .xnet-settings-nav-item:hover {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
    }

    .xnet-settings-nav-item.active {
        background: rgba(0, 122, 255, 0.15);
        color: #007aff;
    }

    .nav-icon {
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        margin-right: 12px;
    }

    .nav-label {
        font-size: 14px;
        font-weight: 500;
    }

    .active-indicator {
        position: absolute;
        right: -16px;
        width: 3px;
        height: 18px;
        background: #007aff;
        border-radius: 4px 0 0 4px;
    }

    .xnet-settings-content {
        flex: 1;
        position: relative;
        padding: 48px;
        overflow-y: auto;
    }

    .content-inner {
        position: relative;
        z-index: 2;
    }

    @@media (max-width: 900px) {
        .xnet-settings-container { flex-direction: column; }
        .xnet-settings-sidebar { width: 100%; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.05); }
    }
</style>

@code {
    [Parameter] public List<CocoTabItem> Tabs { get; set; } = new();
    [Parameter] public string ActiveTab { get; set; } = "";
    [Parameter] public EventCallback<string> OnTabChanged { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    public class CocoTabItem { public string Id { get; set; } = ""; public string Label { get; set; } = ""; public string Icon { get; set; } = ""; }
}
