@namespace XNet.Shared.Components.CocoUi

<button type="@Type" class="coco-btn @Class @(Variant == "primary" ? "btn-primary" : "btn-secondary")" @onclick="OnClick" disabled="@(Disabled || Loading)" style="@Style">
    @if (Loading)
    {
        <div class="coco-loader me-2"></div>
    }
    else if (!string.IsNullOrEmpty(Icon))
    {
        <i class="bi @Icon me-2"></i>
    }
    <span class="btn-label">@ChildContent</span>
</button>

<style>
    .coco-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 24px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.2s cubic-bezier(0.2, 1, 0.2, 1);
        border: none;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .coco-btn.btn-primary {
        background: #007aff;
        color: #fff;
        box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3);
    }

    .coco-btn.btn-primary:hover {
        background: #0071e3;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(0, 123, 255, 0.4);
    }

    .coco-btn.btn-secondary {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .coco-btn.btn-secondary:hover {
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.2);
    }

    .coco-btn:active {
        transform: scale(0.97);
    }

    .coco-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none !important;
    }

    .coco-loader {
        width: 14px;
        height: 14px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: coco-spin 0.6s linear infinite;
    }

    @@keyframes coco-spin {
        to { transform: rotate(360deg); }
    }
</style>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string Style { get; set; } = "";
    [Parameter] public string Variant { get; set; } = "primary";
}
